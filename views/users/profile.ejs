<% layout("/layouts/boilerplate") %>

<style>
  .profile-header {
    background: linear-gradient(135deg, #ff4500, #ff6a33);
    border-radius: 1.5rem;
    padding: 3rem 2rem;
    color: white;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(255, 69, 0, 0.2);
  }
  .profile-header::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    pointer-events: none;
  }
  .avatar-container {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 5px solid rgba(255, 255, 255, 0.3);
    overflow: hidden;
    background: white;
    flex-shrink: 0;
  }
  .avatar-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .profile-info h1 {
    font-weight: 800;
    margin-bottom: 0.2rem;
    font-size: 2.2rem;
  }
  .profile-info p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 1rem;
  }
  .bio-box {
    background: rgba(255, 255, 255, 0.15);
    padding: 1rem;
    border-radius: 1rem;
    backdrop-filter: blur(10px);
    font-size: 0.95rem;
    max-width: 600px;
  }
  .action-buttons .btn {
    border-radius: 50px;
    padding: 0.6rem 1.5rem;
    font-weight: 600;
  }
  .section-title {
    font-weight: 800;
    margin-bottom: 1.5rem;
    position: relative;
    display: inline-block;
  }
  .section-title::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 50%;
    height: 4px;
    background: #ff4500;
    border-radius: 2px;
  }
</style>

<div class="row mt-4">
  <div class="col-12">
    <div class="profile-header d-flex flex-column flex-md-row align-items-center gap-4 text-center text-md-start">
      <div class="avatar-container shadow-sm">
        <img src="<%= user.avatar.url %>" alt="Profile Avatar">
      </div>
      <div class="profile-info flex-grow-1">
        <h1><%= user.username %></h1>
        <p><i class="fa-solid fa-envelope me-2"></i><%= user.email %></p>
        <% if (user.phone) { %>
          <p class="mb-2"><i class="fa-solid fa-phone me-2"></i><%= user.phone %></p>
        <% } %>
        
        <% if (user.bio) { %>
          <div class="bio-box">
            <strong>About me:</strong><br>
            <%= user.bio %>
          </div>
        <% } %>
      </div>
      <div class="action-buttons d-flex flex-column gap-2 mt-3 mt-md-0">
        <a href="/profile/edit" class="btn btn-light text-danger shadow-sm">
          <i class="fa-solid fa-pen-to-square me-2"></i>Edit Profile
        </a>
        <button class="btn btn-outline-light" data-bs-toggle="modal" data-bs-target="#deleteProfileModal">
          <i class="fa-solid fa-trash-can me-2"></i>Delete Account
        </button>
      </div>
    </div>
  </div>
</div>

<div class="row mt-4 mb-5">
  <div class="col-12">
    <h3 class="section-title">My Listings (<%= listings.length %>)</h3>
    
    <% if (listings.length === 0) { %>
      <div class="text-center py-5 bg-white rounded-4 shadow-sm border mt-3">
        <i class="fa-solid fa-house-chimney-crack text-muted mb-3" style="font-size: 3rem;"></i>
        <h5 class="fw-bold">No properties listed yet</h5>
        <p class="text-muted">Start earning by listing your space on Horizon Hub.</p>
        <a href="/listings/new" class="btn btn-danger mt-2 fw-bold px-4 py-2" style="border-radius: 30px;">
          <i class="fa-solid fa-plus me-2"></i>Create Listing
        </a>
      </div>
    <% } else { %>
      <div class="listings-grid mt-4">
        <% for (let listing of listings) { %>
          <a href="/listings/<%= listing._id %>" class="listing-card-wrap">
            <div class="listing-card shadow-sm border">
              <img src="<%= listing.image.url %>" alt="<%= listing.title %>" loading="lazy">
              <div class="listing-card-body p-3">
                <p class="listing-card-title fs-5 fw-bold mb-1"><%= listing.title %></p>
                <p class="listing-card-sub text-muted"><i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %></p>
                <div class="d-flex justify-content-between align-items-center mt-3">
                  <p class="listing-card-price mb-0 fs-6 fw-bold">
                    ₹<%= listing.price.toLocaleString('en-IN') %> <span class="fw-normal text-muted" style="font-size:0.85rem;">/ night</span>
                  </p>
                  <span class="badge bg-light text-danger border"><%= listing.category %></span>
                </div>
              </div>
            </div>
          </a>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteProfileModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 1.5rem; overflow: hidden;">
      <div class="modal-header border-0 bg-danger text-white pb-3">
        <h5 class="modal-title fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i>Delete Account</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body py-4">
        <p class="text-dark fs-5 fw-medium text-center">Are you sure you want to delete your account?</p>
        <p class="text-muted text-center mb-0">This action is <strong>irreversible</strong>. All your personal data, current listings, and reviews will be permanently deleted from our servers.</p>
      </div>
      <div class="modal-footer border-0 justify-content-center pb-4">
        <button type="button" class="btn btn-light px-4 rounded-pill fw-bold" data-bs-dismiss="modal">Cancel</button>
        <form action="/profile?_method=DELETE" method="POST" class="d-inline">
          <button type="submit" class="btn btn-danger px-4 rounded-pill fw-bold">
            <i class="fa-solid fa-trash-can me-1"></i>Yes, Delete Everything
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

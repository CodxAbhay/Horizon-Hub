<% layout("/layouts/boilerplate") %>

<style>
  .search-results-header {
    padding: 1.5rem 0 0.75rem;
    border-bottom: 2px solid #f0f0f0;
    margin-bottom: 1.5rem;
  }

  .search-results-header h2 {
    font-weight: 800;
    font-size: 1.4rem;
    margin: 0;
  }

  .search-results-header .result-count {
    color: #888;
    font-size: 0.9rem;
    margin-top: 0.2rem;
  }

  .search-query {
    color: #ff4500;
    font-style: italic;
  }

  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .listing-card-wrap {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    border-radius: 1rem;
  }

  .listing-card-wrap:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0,0,0,0.12);
  }

  .listing-card {
    border: none;
    border-radius: 1rem;
    overflow: hidden;
    background: #fff;
  }

  .listing-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 1rem;
    transition: transform 0.35s ease;
  }

  .listing-card-wrap:hover img {
    transform: scale(1.04);
  }

  .listing-card-body {
    padding: 0.75rem 0.25rem 0.5rem;
  }

  .listing-card-title {
    font-weight: 700;
    font-size: 0.97rem;
    margin: 0 0 0.1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .listing-card-sub {
    font-size: 0.83rem;
    color: #666;
    margin: 0;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: #888;
  }

  .empty-state i {
    font-size: 3.5rem;
    color: #ddd;
    margin-bottom: 1rem;
  }
</style>

<div class="search-results-header">
  <h2>Search Results for <span class="search-query">"<%= query %>"</span></h2>
  <p class="result-count">
    <i class="fa-solid fa-list me-1"></i>
    <%= allListing.length %> result<%= allListing.length !== 1 ? 's' : '' %> found
  </p>
</div>

<% if (allListing.length === 0) { %>
  <div class="empty-state">
    <div><i class="fa-solid fa-magnifying-glass"></i></div>
    <h4>No listings found</h4>
    <p>We couldn't find any listings matching "<%= query %>". Try searching for a different city, country, or title.</p>
    <a href="/listings" class="btn btn-danger mt-2">
      <i class="fa-solid fa-arrow-left me-1"></i>Back to All Listings
    </a>
  </div>
<% } else { %>
  <div class="listings-grid">
    <% for (let list of allListing) { %>
      <a href="/listings/<%= list._id %>" class="listing-card-wrap">
        <div class="listing-card">
          <img src="<%= list.image.url %>" alt="<%= list.title %>" loading="lazy">
          <div class="listing-card-body">
            <p class="listing-card-title"><%= list.title %></p>
            <p class="listing-card-sub">
              <i class="fa-solid fa-location-dot me-1" style="color:#ff4500;"></i>
              <%= list.location %>, <%= list.country %>
            </p>
            <p class="listing-card-sub mt-1 fw-bold" style="color:#222;">
              ₹<%= list.price.toLocaleString('en-IN') %><span style="font-weight:400;color:#666;"> / night</span>
            </p>
          </div>
        </div>
      </a>
    <% } %>
  </div>
  <div class="text-center pb-4">
    <a href="/listings" class="btn btn-outline-secondary">
      <i class="fa-solid fa-arrow-left me-1"></i>Back to All Listings
    </a>
  </div>
<% } %>
